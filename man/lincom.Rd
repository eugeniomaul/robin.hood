\name{lincom}
\alias{lincom}
\title{Linear Combinations}
\description{Calculates linear combinations of model coefficients.}
\usage{
lincom(model, betas = NULL, mag = NULL)
}
\arguments{
  \item{model}{A fitted model object.}
  \item{betas}{Character vector of coefficient names.}
  \item{mag}{Numeric vector of magnitudes.}
}
